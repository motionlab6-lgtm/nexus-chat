<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nexus</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        body { display: flex; height: 100vh; background-color: #111b21; justify-content: center; align-items: center; overflow: hidden; }
        
        /* ================= DISCORD-STYLE LOGIN PROFILE GATEWAY ================= */
        .login-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at 50% 50%, #222531 0%, #0f1015 100%); display: flex; justify-content: center; align-items: center; z-index: 100; transition: all 0.4s ease; }
        .login-card { background: rgba(49, 51, 56, 0.9); backdrop-filter: blur(16px); width: 90%; max-width: 420px; padding: 36px 28px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); color: #b5bac1; border: 1px solid rgba(255,255,255,0.04); }
        .login-card h2 { color: #fff; font-size: 26px; margin-bottom: 6px; font-weight: 700; }
        .login-card p { font-size: 13.5px; margin-bottom: 24px; color: #949ba4; }
        .form-group { text-align: left; margin-bottom: 18px; }
        .form-group label { display: block; font-size: 11px; font-weight: 700; color: #b5bac1; text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.6px; }
        .login-input { width: 100%; padding: 11px 14px; background-color: #1e1f22; border: 1px solid rgba(0,0,0,0.4); border-radius: 5px; color: #dbdee1; font-size: 15px; outline: none; }
        .login-input:focus { border-color: #5865f2; }
        .toggle-reg-text { font-size: 13px; color: #5865f2; cursor: pointer; text-decoration: underline; margin-top: 14px; display: inline-block; }

        /* ================= MAIN NEXUS APPLICATION CONTAINER ================= */
        .app-window { display: flex; width: 100%; height: 100%; background-color: #fff; overflow: hidden; visibility: hidden; opacity: 0; transition: opacity 0.4s ease; }
        
        /* ================= WHATSAPP STYLE SIDEBAR ARCHITECTURE ================= */
        .sidebar { width: 30%; max-width: 420px; min-width: 320px; background-color: #fff; border-right: 1px solid #e9edef; display: flex; flex-direction: column; position: relative; }
        .sidebar-header { background-color: #f0f2f5; height: 60px; padding: 10px 16px; display: flex; align-items: center; justify-content: space-between; }
        .avatar { width: 40px; height: 40px; background-color: #5865f2; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; text-transform: uppercase; font-size: 15px; cursor: pointer; }
        .app-title { font-weight: 800; color: #5865f2; font-size: 21px; letter-spacing: 0.2px; }
        .action-icon { font-size: 20px; cursor: pointer; color: #54656f; user-select: none; }

        .search-box { padding: 8px 12px; background-color: #fff; border-bottom: 1px solid #e9edef; }
        .search-inner { background-color: #f0f2f5; width: 100%; padding: 6px 14px; border-radius: 8px; }
        .search-inner input { width: 100%; border: none; background: transparent; outline: none; font-size: 14px; }

        .chats-list { flex: 1; overflow-y: auto; }
        .chat-item { display: flex; padding: 12px 16px; align-items: center; background-color: #f0f2f5; border-bottom: 1px solid #e9edef; }
        .chat-item-info { flex: 1; margin-left: 14px; }
        .chat-item-header { display: flex; justify-content: space-between; align-items: center; }
        .chat-item-header h4 { font-size: 15.5px; color: #111b21; font-weight: 600; }
        .chat-item-preview { font-size: 13px; color: #00a884; font-weight: 500; margin-top: 2px; }

        /* ================= SETTINGS OVERLAY PANEL ================= */
        .settings-panel { position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: #f0f2f5; z-index: 50; transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; }
        .settings-panel.open { left: 0; }
        .settings-header { background: #008069; color: white; height: 100px; padding: 20px 16px; display: flex; align-items: flex-end; gap: 20px; font-size: 19px; font-weight: 500; }
        .settings-body { padding: 20px; display: flex; flex-direction: column; gap: 20px; background: #fff; flex: 1; }
        .settings-input-box label { font-size: 12px; color: #008069; font-weight: 600; text-transform: uppercase; }
        .settings-input-box input { width: 100%; padding: 10px 0; border: none; border-bottom: 2px solid #e9edef; outline: none; font-size: 16px; margin-top: 5px; }
        .settings-input-box input:focus { border-bottom-color: #008069; }

        /* ================= CHAT STREAM MAIN PANEL ================= */
        .chat-panel { flex: 1; display: flex; flex-direction: column; background-color: #efeae2; position: relative; }
        .chat-panel::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.05; background-image: radial-gradient(#000 10%, transparent 10%), radial-gradient(#000 10%, transparent 10%); background-size: 20px 20px; background-position: 0 0, 10px 10px; pointer-events: none; }
        .chat-header { background-color: #f0f2f5; height: 60px; padding: 10px 16px; display: flex; align-items: center; border-bottom: 1px solid #e9edef; z-index: 10; justify-content: space-between; }
        .chat-header-left { display: flex; align-items: center; }
        .chat-header-info { margin-left: 14px; }
        .chat-header-info h4 { font-size: 16px; color: #111b21; font-weight: 500; }
        .chat-header-info p { font-size: 13px; color: #667781; }

        .chat-container { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 6px; z-index: 10; }
        .message { max-width: 70%; padding: 6px 10px 8px 10px; border-radius: 7px; font-size: 14.2px; line-height: 19px; color: #111b21; position: relative; box-shadow: 0 1px 0.5px rgba(11,20,26,.13); }
        .sent { background-color: #d9fdd3; align-self: flex-end; border-top-right-radius: 0; }
        .received { background-color: #ffffff; align-self: flex-start; border-top-left-radius: 0; }
        .username { font-size: 12px; color: #53bdeb; display: block; margin-bottom: 2px; font-weight: 600; }
        .sent .username { color: #5865f2; }

        /* ================= ADMIN CONSOLE WRAPPER ================= */
        .admin-dashboard { display: none; background: #313338; color: white; padding: 12px 24px; z-index: 20; border-bottom: 2px solid #5865f2; align-items: center; gap: 15px; justify-content: center; }
        .admin-input { padding: 6px 10px; background: #1e1f22; border: none; border-radius: 4px; color: white; outline: none; width: 160px; }
        .admin-select { padding: 6px 10px; background: #1e1f22; color: white; border: none; border-radius: 4px; }
        .admin-btn { background: #5865f2; border: none; color: white; padding: 6px 14px; border-radius: 4px; cursor: pointer; font-weight: 600; }

        .input-area { background-color: #f0f2f5; padding: 10px 16px; display: flex; align-items: center; gap: 10px; z-index: 10; }
        .input-area input { flex: 1; padding: 11px 16px; border: none; border-radius: 8px; outline: none; font-size: 15px; }
        .input-area button { background-color: #5865f2; color: white; border: none; padding: 11px 24px; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600; }

        @media (max-width: 768px) {
            .sidebar { display: none; }
            .message { max-width: 85%; }
            .admin-dashboard { flex-wrap: wrap; gap: 8px; }
        }
    </style>
</head>
<body>

    <div class="login-screen" id="loginScreen">
        <div class="login-card">
            <h2 id="authHeading">Welcome Back</h2>
            <p id="authSubtitle">Please sign in with your email account.</p>
            
            <div class="form-group" id="regField" style="display: none;">
                <label>Display Name (Username)</label>
                <input type="text" id="usernameInput" class="login-input" placeholder="What should we call you?">
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input type="email" id="emailInput" class="login-input" placeholder="Enter email address">
            </div>
            
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="passwordInput" class="login-input" placeholder="Enter password">
            </div>
            
            <button class="login-btn" id="loginBtn">Sign In</button>
            <div class="toggle-reg-text" id="toggleAuthMode">Need an account? Register instead</div>
        </div>
    </div>

    <div class="app-window" id="appWindow">
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="avatar" id="myAvatar" onclick="toggleSettings(true)">U</div>
                <div class="app-title">NEXUS</div>
                <div class="action-icon" onclick="toggleSettings(true)">⚙️</div>
            </div>
            
            <div class="search-box">
                <div class="search-inner">
                    <input type="text" placeholder="Search or start a new chat">
                </div>
            </div>

            <div class="chats-list">
                <div class="chat-item">
                    <div class="avatar" style="background-color: #4e5058">N</div>
                    <div class="chat-item-info">
                        <div class="chat-item-header">
                            <h4>Global Lounge</h4>
                        </div>
                        <div class="chat-item-preview">authenticated server stream...</div>
                    </div>
                </div>
            </div>

            <div class="settings-panel" id="settingsPanel">
                <div class="settings-header">
                    <span style="cursor:pointer;" onclick="toggleSettings(false)">←</span>
                    <span>Profile Settings</span>
                </div>
                <div class="settings-body">
                    <div class="settings-input-box">
                        <label>Your Name</label>
                        <input type="text" id="settingsNameInput">
                        <button class="login-btn" style="margin-top:15px;" onclick="saveProfileName()">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="chat-panel">
            <div class="admin-dashboard" id="adminDashboard">
                <span>🛡️ Nexus Control Console:</span>
                <input type="text" class="admin-input" id="adminTarget" placeholder="Target Username">
                <select class="admin-select" id="adminAction">
                    <option value="ban">Ban User</option>
                    <option value="unban">Unban User</option>
                    <option value="makeadmin">Promote to Admin</option>
                </select>
                <button class="admin-btn" onclick="fireAdminAction()">Execute Command</button>
            </div>

            <div class="chat-header">
                <div class="chat-header-left">
                    <div class="avatar" style="background-color: #5865f2;">N</div>
                    <div class="chat-header-info">
                        <h4>Global Lounge</h4>
                        <p>encrypted feed</p>
                    </div>
                </div>
            </div>
            
            <div class="chat-container" id="chatContainer"></div>

            <div class="input-area">
                <input type="text" id="messageInput" placeholder="Type a message" autocomplete="off">
                <button id="sendBtn">Send</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let isRegistering = false;
        let myUsername = "";

        const loginScreen = document.getElementById('loginScreen');
        const appWindow = document.getElementById('appWindow');
        const loginBtn = document.getElementById('loginBtn');
        const usernameInput = document.getElementById('usernameInput');
        const emailInput = document.getElementById('emailInput');
        const passwordInput = document.getElementById('passwordInput');
        const toggleAuthMode = document.getElementById('toggleAuthMode');
        
        const chatContainer = document.getElementById('chatContainer');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');

        // Toggle authentication modes
        toggleAuthMode.addEventListener('click', () => {
            isRegistering = !isRegistering;
            document.getElementById('regField').style.display = isRegistering ? 'block' : 'none';
            document.getElementById('authHeading').innerText = isRegistering ? 'Create Account' : 'Welcome Back';
            document.getElementById('authSubtitle').innerText = isRegistering ? 'Sign up to get access to Nexus.' : 'Please sign in with your email account.';
            loginBtn.innerText = isRegistering ? 'Register' : 'Sign In';
            toggleAuthMode.innerText = isRegistering ? 'Already have an account? Sign in' : 'Need an account? Register instead';
        });

        loginBtn.addEventListener('click', () => {
            const data = {
                email: emailInput.value.trim(),
                password: passwordInput.value,
                username: isRegistering ? usernameInput.value.trim() : null
            };
            if(!data.email || !data.password || (isRegistering && !data.username)) {
                return alert("All authentication input boxes must be filled out!");
            }
            socket.emit('auth user', data);
        });

        socket.on('auth error', (err) => alert(err));

        socket.on('auth success', (user) => {
            myUsername = user.username;
            loginScreen.style.opacity = "0";
            loginScreen.style.visibility = "hidden";
            appWindow.style.visibility = "visible";
            appWindow.style.opacity = "1";
            
            document.getElementById('myAvatar').innerText = myUsername.charAt(0);
            document.getElementById('settingsNameInput').value = myUsername;

            // Unlock secret admin dash if server flag matches true
            if (user.isAdmin) {
                document.getElementById('adminDashboard').style.display = 'flex';
            }
        });

        // Toggle sliding profiles panel view
        function toggleSettings(open) {
            document.getElementById('settingsPanel').classList.toggle('open', open);
        }

        function saveProfileName() {
            const name = document.getElementById('settingsNameInput').value;
            socket.emit('update profile', name);
        }

        socket.on('profile error', (err) => alert(err));
        socket.on('profile updated', (newName) => {
            myUsername = newName;
            document.getElementById('myAvatar').innerText = myUsername.charAt(0);
            alert("Username profile successfully saved to identity records!");
            toggleSettings(false);
        });

        function fireAdminAction() {
            const target = document.getElementById('adminTarget').value.trim();
            const action = document.getElementById('adminAction').value;
            if(!target) return alert("Target account parameter required.");
            socket.emit('admin command', { target, action });
        }

        socket.on('admin response', (msg) => alert(msg));

        function sendMessage() {
            const text = messageInput.value.trim();
            if (text !== '') {
                socket.emit('chat message', { text: text });
                messageInput.value = '';
            }
        }

        sendBtn.addEventListener('click', sendMessage);
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        socket.on('chat message', (data) => {
            const messageElement = document.createElement('div');
            messageElement.className = `message ${data.user === myUsername ? 'sent' : 'received'}`;
            messageElement.innerHTML = `<span class="username">${data.user}</span>${data.text}`;
            chatContainer.appendChild(messageElement);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        });
    </script>
</body>
</html>